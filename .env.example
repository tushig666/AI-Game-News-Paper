# Database Configuration
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/game_news_ai
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# API Keys
OPENAI_API_KEY=sk-your-openai-key-here
CLAUDE_API_KEY=sk-your-claude-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# AI Service Configuration
AI_PROVIDER=claude  # Options: claude, openai
AI_MODEL_SUMMARIZE=claude-3-5-sonnet-20241022
AI_MODEL_FALLBACK=gpt-4-turbo
AI_TIMEOUT_SECONDS=60
AI_RETRIES=3
AI_BACKOFF_FACTOR=1.5

# Scraping Configuration
SCRAPER_CONCURRENT_WORKERS=4
SCRAPER_TIMEOUT_SECONDS=30
SCRAPER_RETRY_ATTEMPTS=3
SCRAPER_RETRY_BACKOFF=2
SCRAPER_REQUEST_TIMEOUT=15
SCRAPER_USER_AGENTS_COUNT=5
SCRAPING_INTERVAL_MINUTES=30

# Rate Limiting
RATE_LIMIT_PER_SECOND=2
RATE_LIMIT_PER_SITE=1

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_BYTES=10485760  # 10 MB
LOG_BACKUP_COUNT=5

# Environment
ENVIRONMENT=development
DEBUG=True
HOST=0.0.0.0
PORT=8000

# Services
ENABLE_HEALTH_CHECK=True
ENABLE_METRICS=True
ENABLE_CACHING=True

# Export Configuration
EXPORT_FORMAT=json  # Options: json, csv, both
EXPORT_PATH=./exports
EXPORT_BATCH_SIZE=50

# Redis Cache (Optional)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# Monitoring
SENTRY_DSN=https://your-sentry-key@sentry.io/project-id
ENABLE_SENTRY=False

# Feature Flags
FEATURE_DUPLICATE_DETECTION=True
FEATURE_SENTIMENT_ANALYSIS=True
FEATURE_TREND_PREDICTION=True
